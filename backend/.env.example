# Firebase service account JSON file path
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Base64-encoded Firebase credentials JSON (for Render deployment)
# To generate: base64 -i firebase-credentials.json | tr -d '\n'
GOOGLE_CREDENTIALS_JSON=

# Google Gemini API key (REQUIRED for analysis)
GEMINI_API_KEY=your-gemini-api-key-here

# Risk score threshold for auto-escalation (0-100)
ESCALATION_THRESHOLD=70

# Internal API key for write-endpoint protection (empty = disabled / dev mode)
INTERNAL_API_KEY=

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001

# WhatsApp Cloud API (Meta) — FREE: 1,000 messages/month
# Setup: https://developers.facebook.com → Create App → Business → Add WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Comma-separated phone numbers for escalation alerts (with country code)
# Example: 919876543210,919876543211
ESCALATION_WHATSAPP_RECIPIENTS=

# Legacy notification keys (optional)
WHATSAPP_API_KEY=
SMS_API_KEY=

# Google Places API (New) — fetch real public reviews from Google Maps
# Get API key: https://console.cloud.google.com → Enable "Places API (New)"
GOOGLE_PLACES_API_KEY=
# Comma-separated place_id:branch_id pairs. 
# To ONLY fetch Prasad Food Divine branches, use the ID finder tool below on their exact Google Maps locations:
# Find Place IDs: https://developers.google.com/maps/documentation/places/web-service/place-id-finder
# Example for Prasad Food Divine, Kalyan: ChIJk_...:b1,ChIJ...:b2
GOOGLE_PLACE_IDS=
