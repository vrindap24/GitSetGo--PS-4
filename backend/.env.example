# Firebase service account JSON file path
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Base64-encoded Firebase credentials JSON (for Render deployment)
# To generate: base64 -i firebase-credentials.json | tr -d '\n'
GOOGLE_CREDENTIALS_JSON=

# Google Gemini API key (REQUIRED for analysis)
GEMINI_API_KEY=your-gemini-api-key-here

# Risk score threshold for auto-escalation (0-100)
ESCALATION_THRESHOLD=70

# Internal API key for write-endpoint protection (empty = disabled / dev mode)
INTERNAL_API_KEY=

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001

# WhatsApp Business API key (Twilio / Meta) - PLACEHOLDER
WHATSAPP_API_KEY=

# SMS API key (Twilio) - PLACEHOLDER
SMS_API_KEY=
